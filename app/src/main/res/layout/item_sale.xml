<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvInvoiceId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INV001"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/tvInvoiceId"
            android:background="@android:color/holo_green_light"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="Paid"
            android:textColor="@color/white"
            android:textSize="10sp" />

        <LinearLayout
            android:id="@+id/llActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@android:drawable/ic_menu_view"
                android:drawablePadding="4dp"
                android:text="View"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:gravity="center_vertical"
                android:layout_marginEnd="16dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnPrint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@android:drawable/ic_menu_save"
                android:drawablePadding="4dp"
                android:text="Print Invoice"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCustomerInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvInvoiceId"
            android:layout_marginTop="8dp"
            android:text="Customer: John Doe • 9876543210"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvCustomerInfo"
            android:layout_marginTop="4dp"
            android:text="Date: 2025-01-27"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDate"
            android:layout_marginTop="4dp"
            android:text="Items: 1 • Total: ₹3500"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvAmountDue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvSummary"
            android:layout_marginTop="4dp"
            android:text="Amount Due: ₹1050"
            android:textSize="12sp"
            android:textColor="@color/error_red"
            android:visibility="gone" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>